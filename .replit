language = "nodejs"
run = "npm start"
entrypoint = "index.js"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_11"
packages = ["libuuid"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard Dev Server"

[[workflows.workflow]]
name = "Dashboard Dev Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd dashboard && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
