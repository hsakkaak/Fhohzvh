language = "nodejs"
run = "npm start"
entrypoint = "index.js"
modules = ["web", "nodejs-20"]

[nix]
channel = "stable-25_05"
packages = ["libuuid"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Main Bot Application"

[[workflows.workflow]]
name = "Main Bot Application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 7177
externalPort = 3000
