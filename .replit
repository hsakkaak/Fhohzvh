language = "nodejs"
run = "npm start"
entrypoint = "index.js"
modules = ["web", "nodejs-20"]

[nix]
channel = "stable-25_05"
packages = ["libuuid"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard Dev Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Main Bot"

[[workflows.workflow]]
name = "Dashboard Dev Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd dashboard && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Main Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 7177
externalPort = 3000
